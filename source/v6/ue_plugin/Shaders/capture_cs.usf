#include "Common.usf"

RWTexture2D< float > OutputSurface;

[numthreads(32, 32, 1)]
void MainComputeShader( uint3 ThreadId : SV_DispatchThreadID )
{
	uint2 pixelPos = ThreadId.xy;
	const float sceneDepth = CalcSceneDepth( pixelPos );
	OutputSurface[ThreadId.xy] = sceneDepth;
}
